{
    "permissions": {
      "allow": [
          "Read",
          "Edit",
          "Write"
        ],
        "ask": [
          "Bash(npm *)",
          "Bash(npx *)",
          "Bash(node *)",
          "Bash(git add *)",
          "Bash(git commit *)",
          "Bash(git diff *)",
          "Bash(git log *)",
          "Bash(git status *)",
          "Bash(git branch *)",
          "Bash(git checkout *)",
          "Bash(git stash *)",
          "Bash(curl *)"
    ],
    "deny": [
          "Bash(wget *)",
          "Bash(git push *)",
          "Bash(git push)",
          "Bash(rm -rf *)"
      ]
    },
    "hooks": {
      "PostToolUse": [
        {
          "matcher": "Write|Edit",
          "hooks": [
            {
              "type": "command",
              "command": "npx eslint --fix . --quiet",
              "timeout": 10000
            },
            {
              "type": "command",
              "command": "npx tsc --noEmit",
              "timeout": 30000
            }
          ]
        }
      ]
    }
  }
  