# Supabase project URL — Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only, never expose to the browser
# Supabase dashboard → Project Settings → API → Service role key
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Supavisor transaction-mode URL (port 6543, NOT session-mode port 5432)
# Supabase dashboard → Project Settings → Database → Connection string → Transaction mode
DATABASE_URL=

# Resend API key — server-only, never expose to the browser
# Resend dashboard → API Keys
RESEND_API_KEY=

# Verified sender address for lesson-link emails — Resend dashboard → Domains
EMAIL_FROM=

# Base URL used to build the emailed /lesson/<token> link (no trailing slash)
# e.g. https://your-app.vercel.app in production, http://localhost:3000 in dev
NEXT_PUBLIC_APP_URL=

# OpenAI API key — server-only, never expose to the browser
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model used to generate candidate rejection reasons (plain model id, no prefix)
# Defaults to a small/cheap model if unset — see src/lib/ai/suggestRejectionReasons.ts
AI_SUGGESTION_MODEL=
